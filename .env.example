# =============================================================================
# CondoCombat — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
# =============================================================================

# --- SECRET_KEY (OBRIGATÓRIO) ---
# Chave secreta para assinatura de tokens JWT.
# Gere uma com: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=

# --- Banco de Dados (PostgreSQL) ---
# URL de conexão do backend com o banco PostgreSQL.
# Formato: postgresql+asyncpg://usuario:senha@host:porta/database
DATABASE_URL=postgresql+asyncpg://condocombat:condocombat@db:5432/condocombat

# Credenciais do PostgreSQL (usadas pelo serviço db no docker-compose)
POSTGRES_USER=condocombat
POSTGRES_PASSWORD=condocombat
POSTGRES_DB=condocombat

# --- Frontend ---
# URL base da API para o frontend Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- CORS ---
# Origens permitidas para CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000
